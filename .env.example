# =============================================================
# Rosterly Environment Variables
# =============================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# Validated at build time by T3 Env (src/lib/env.ts).
# The app will NOT start if required variables are missing.
# =============================================================

# ── Clerk Authentication (required) ──
# Get these from https://dashboard.clerk.com → your app → API Keys
# Use pk_test_ / sk_test_ for development, pk_live_ / sk_live_ for production
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Clerk route configuration ──
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── External REST API (required for backend connection) ──
# This URL is used by Next.js rewrites to proxy /api/v1/* requests to your backend.
# In development: http://localhost:8765
# In production: https://api.yourdomain.com
EXTERNAL_API_URL=http://localhost:8765
# API_SECRET_KEY=

# ── Public API base URL ──
# Leave empty to use the Next.js proxy (recommended - avoids CORS issues).
# Only set this if you need direct browser-to-backend calls with CORS configured.
NEXT_PUBLIC_API_URL=

# ── Logfire / OpenTelemetry (server-side) ──
# Standard OTEL vars consumed by @vercel/otel — NOT validated by T3 Env.
# Get your write token from https://logfire.pydantic.dev
OTEL_EXPORTER_OTLP_ENDPOINT=https://logfire-api.pydantic.dev
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer <your-logfire-write-token>"
# Environment label shown in Logfire dashboard (e.g., "adam-local", "staging", "prod")
LOGFIRE_ENVIRONMENT=adam-local
