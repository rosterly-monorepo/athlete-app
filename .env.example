# =============================================================
# AthleteHub Environment Variables
# =============================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# Validated at build time by T3 Env (src/lib/env.ts).
# The app will NOT start if required variables are missing.
# =============================================================

# ── Clerk Authentication (required) ──
# Get these from https://dashboard.clerk.com → your app → API Keys
# Use pk_test_ / sk_test_ for development, pk_live_ / sk_live_ for production
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Clerk route configuration ──
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── External REST API (optional — uncomment when backend is connected) ──
# EXTERNAL_API_URL=https://api.yourdomain.com
# API_SECRET_KEY=

# ── Public API base URL (leave empty to use same-origin /api routes) ──
NEXT_PUBLIC_API_URL=
